rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /app_config/{document} {
      allow read, write: if true;
    }
    match /uploaded_files/{fileId} {
      allow read, write: if true;
      match /chunks/{chunkId} {
        allow read, write: if true;
      }
    }
  }
}
